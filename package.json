{
  "name": "openunum",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "openunum": "src/cli.mjs"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "cli": "node src/cli.mjs",
    "bootstrap": "node bootstrap.mjs",
    "test:self": "node tests/self-test-runner.mjs",
    "test:unit": "vitest run tests/unit",
    "test:health": "node -e \"import('./src/core/self-test.mjs').then(m => new m.SelfTester({config:await import('./src/config.mjs').then(c=>c.loadConfig()),memory:await import('./src/memory/store.mjs').then(m=>new m.MemoryStore()),agent:null,browser:null}).runAll())\"",
    "phase0:e2e": "node tests/phase0.e2e.mjs",
    "phase1:e2e": "node tests/phase1.e2e.mjs",
    "phase2:e2e": "node tests/phase2.e2e.mjs",
    "phase3:e2e": "node tests/phase3.e2e.mjs",
    "phase4:e2e": "node tests/phase4.e2e.mjs",
    "phase5:e2e": "node tests/phase5.e2e.mjs",
    "phase6:e2e": "node tests/phase6.e2e.mjs",
    "phase7:e2e": "node tests/phase7.e2e.mjs",
    "phase8:e2e": "node tests/phase8.e2e.mjs",
    "phase9:e2e": "node tests/phase9.e2e.mjs",
    "phase10:e2e": "node tests/phase10.e2e.mjs",
    "phase11:e2e": "node tests/phase11.e2e.mjs",
    "phase12:e2e": "node tests/phase12.openai-codex-provider.e2e.mjs",
    "phase13:e2e": "node tests/phase13.google-workspace-native.e2e.mjs",
    "phase14:e2e": "node tests/phase14.controller-behavior.e2e.mjs",
    "phase15:e2e": "node tests/phase15.session-delete.e2e.mjs",
    "phase36:e2e": "node tests/phase36.self-monitoring.e2e.mjs",
    "phase37:e2e": "node tests/phase37.predictive-failure-task-orchestrator.e2e.mjs",
    "e2e": "pnpm phase0:e2e && pnpm phase1:e2e && pnpm phase2:e2e && pnpm phase3:e2e && pnpm phase4:e2e && pnpm phase5:e2e && pnpm phase6:e2e && pnpm phase7:e2e && pnpm phase8:e2e && pnpm phase9:e2e && pnpm phase10:e2e && pnpm phase11:e2e && pnpm phase12:e2e && pnpm phase13:e2e && pnpm phase14:e2e && pnpm phase15:e2e && pnpm phase36:e2e && pnpm phase37:e2e",
    "test:all": "pnpm test:self && pnpm e2e",
    "research:daily": "node src/scripts/research-daily.mjs",
    "hf:explore": "node scripts/hf-dataset-explore.mjs",
    "hf:pilot": "node scripts/hf-pilot-ingest.mjs",
    "deploy:gate": "pnpm test:all && node tests/self-test-runner.mjs",
    "smoke:check": "node scripts/smoke-check.mjs",
    "smoke:ui:noauth": "node scripts/ui-smoke-noauth.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.64.0",
    "chrome-remote-interface": "^0.33.3",
    "dotenv": "^16.6.1",
    "marked": "^15.0.12",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
